---
const currentYear = new Date().getFullYear();
---
<footer class="bg-slate-900 dark:bg-slate-950 text-slate-400 pt-14 pb-8 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Marca -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4 cursor-pointer">
          <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C9.5 2 8 4 8 6C8 8 9 9.5 10 10.5C8 11 5 13 5 17C5 20 7.5 22 12 22C16.5 22 19 20 19 17C19 13 16 11 14 10.5C15 9.5 16 8 16 6C16 4 14.5 2 12 2Z" fill="white"/>
              <path d="M12 6C12 6 13 7.5 13 9C13 10.5 12 11 12 11C12 11 11 10.5 11 9C11 7.5 12 6 12 6Z" fill="#16a34a"/>
            </svg>
          </div>
          <span class="font-extrabold text-lg text-white">MiAgroGestion</span>
        </a>
        <p class="text-sm leading-relaxed mb-4">
          Software de gestión para granjas de gallinas ponedoras en Perú y Latinoamérica.
        </p>
        <a
          href="https://wa.me/51955497368"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-brand-400 hover:text-brand-300 transition-colors cursor-pointer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.06 1.2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.19a16 16 0 0 0 5.72 5.72l1.26-1.26a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 15z"/></svg>
          +51 955 497 368
        </a>
      </div>

      <!-- Producto -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Producto</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="#funcionalidades" class="hover:text-white transition-colors cursor-pointer">Funcionalidades</a></li>
          <li><a href="#precios" class="hover:text-white transition-colors cursor-pointer">Precios</a></li>
          <li><a href="#como-funciona" class="hover:text-white transition-colors cursor-pointer">Cómo funciona</a></li>
          <li><a href="https://app.miagrogesion.com/registro" class="hover:text-white transition-colors cursor-pointer">Prueba gratis 14 días</a></li>
          <li><a href="https://app.miagrogestion.com/login" class="hover:text-white transition-colors cursor-pointer">Iniciar sesión</a></li>
        </ul>
      </div>

      <!-- Recursos -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Recursos</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/blog" class="hover:text-white transition-colors cursor-pointer">Blog avícola</a></li>
          <li><a href="/guia-postura" class="hover:text-white transition-colors cursor-pointer">Guía de % postura</a></li>
          <li><a href="/calculadora-rentabilidad" class="hover:text-white transition-colors cursor-pointer">Calculadora de rentabilidad</a></li>
          <li><a href="#faq" class="hover:text-white transition-colors cursor-pointer">Preguntas frecuentes</a></li>
        </ul>
      </div>

      <!-- Empresa -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Empresa</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/sobre-nosotros" class="hover:text-white transition-colors cursor-pointer">Sobre nosotros</a></li>
          <li><a href="/contacto" class="hover:text-white transition-colors cursor-pointer">Contacto</a></li>
          <li><a href="/terminos" class="hover:text-white transition-colors cursor-pointer">Términos de servicio</a></li>
          <li><a href="/privacidad" class="hover:text-white transition-colors cursor-pointer">Política de privacidad</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs">
      <p>© {currentYear} MiAgroGestion. Todos los derechos reservados.</p>
      <p>Hecho con cariño para los granjeros de Latinoamérica 🇵🇪</p>
    </div>
  </div>
</footer>
