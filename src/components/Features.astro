---
const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>`,
    title: 'Control de % postura en tiempo real',
    desc: 'Calcula automáticamente huevos ÷ gallinas vivas × 100. Ve la tendencia de cada lote y detecta caídas antes de que se conviertan en pérdidas.',
    highlight: true,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4M12 16h4M8 11h.01M8 16h.01"/></svg>`,
    title: 'Registro diario por turno',
    desc: 'Registra huevos por turno (mañana/tarde), mortalidad, alimento y agua en menos de 30 segundos. Funciona sin internet.',
    highlight: false,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    title: 'Dashboard con KPIs del mes',
    desc: 'Huevos producidos, ingresos, utilidad neta y lotes activos en una sola pantalla. Gráfico de 30 días para ver tendencias.',
    highlight: false,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>`,
    title: 'Ventas por talla y unidad',
    desc: 'Registra ventas de huevos en Placas, Docenas o Unidades. Por talla: Jumbo, Grande, Mediano y Descarte. Control de clientes y cobros.',
    highlight: false,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
    title: 'Alertas automáticas de stock',
    desc: 'Recibe alertas cuando el inventario de alimento, medicina o insumos cae por debajo del mínimo. Sin sorpresas.',
    highlight: false,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    title: 'Rentabilidad real por galpón',
    desc: 'Controla gastos de alimento, medicina, mano de obra y transporte. Calcula tu utilidad neta y costo por huevo cada mes.',
    highlight: false,
  },
];
---
<section id="funcionalidades" class="py-20 bg-white dark:bg-slate-950 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <p class="text-brand-600 dark:text-brand-400 font-semibold text-sm uppercase tracking-wider mb-3">Funcionalidades</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-4 text-balance">
        Todo lo que necesita tu granja en un solo lugar
      </h2>
      <p class="text-slate-600 dark:text-slate-400 text-lg">
        11 módulos integrados. Diseñado para operadores de campo, no para contadores.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <div class={`rounded-2xl p-6 border transition-shadow hover:shadow-md ${
          f.highlight
            ? 'bg-brand-600 border-brand-700'
            : 'bg-white dark:bg-slate-900 border-slate-100 dark:border-slate-800'
        }`}>
          <div class={`w-11 h-11 rounded-xl flex items-center justify-center mb-4 ${
            f.highlight
              ? 'bg-white/20 text-white'
              : 'bg-brand-50 dark:bg-brand-600/20 text-brand-600 dark:text-brand-400'
          }`}>
            <Fragment set:html={f.icon} />
          </div>
          <h3 class={`font-bold text-lg mb-2 ${f.highlight ? 'text-white' : 'text-slate-900 dark:text-white'}`}>{f.title}</h3>
          <p class={`text-sm leading-relaxed ${f.highlight ? 'text-white/80' : 'text-slate-600 dark:text-slate-400'}`}>{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
