---
const plans = [
  {
    name: 'Prueba',
    price: 'Gratis',
    period: '14 días',
    desc: 'Todas las funcionalidades sin límites para que pruebes sin riesgo',
    features: [
      '3 granjas · 15 galpones · 20 lotes',
      'Todos los módulos activos',
      '5 usuarios incluidos',
      'Sin tarjeta de crédito',
      'Soporte por WhatsApp',
    ],
    cta: 'Empezar prueba gratis',
    ctaLink: 'https://app.miagrogesion.com/registro',
    popular: false,
    variant: 'outline',
  },
  {
    name: 'Productor',
    price: 'S/ 49',
    period: '/ mes',
    desc: 'Para granjas pequeñas que ya quieren control profesional',
    features: [
      '1 granja · 5 galpones · 10 lotes activos',
      'Todos los módulos incluidos',
      '1 usuario',
      'Reportes PDF',
      'Alertas de stock e inventario',
    ],
    cta: 'Empezar ahora',
    ctaLink: 'https://app.miagrogesion.com/registro?plan=productor',
    popular: false,
    variant: 'default',
  },
  {
    name: 'Profesional',
    price: 'S/ 99',
    period: '/ mes',
    desc: 'Para granjas medianas con varios galpones y equipo de trabajo',
    features: [
      '3 granjas · 15 galpones · 20 lotes',
      'Todos los módulos incluidos',
      '5 usuarios',
      'Export CSV / Excel',
      'Historial ilimitado',
    ],
    cta: 'Empezar ahora',
    ctaLink: 'https://app.miagrogesion.com/registro?plan=profesional',
    popular: true,
    variant: 'highlight',
  },
  {
    name: 'Empresa',
    price: 'S/ 199',
    period: '/ mes',
    desc: 'Para integradoras y operaciones de gran escala',
    features: [
      'Granjas, galpones y lotes ilimitados',
      'Todos los módulos incluidos',
      '10 usuarios',
      'API e integraciones',
      'Soporte prioritario dedicado',
    ],
    cta: 'Hablar con ventas',
    ctaLink: 'https://wa.me/51955497368?text=Hola%2C%20me%20interesa%20el%20plan%20Empresa%20de%20MiAgroGestion',
    popular: false,
    variant: 'dark',
  },
];
---
<section id="precios" class="py-20 bg-white dark:bg-slate-950 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <p class="text-brand-600 dark:text-brand-400 font-semibold text-sm uppercase tracking-wider mb-3">Precios</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-4 text-balance">
        Planes para cada tamaño de granja
      </h2>
      <p class="text-slate-600 dark:text-slate-400 text-lg">
        Empieza con 14 días gratis. Sin contratos, cancela cuando quieras.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 items-start">
      {plans.map((plan) => (
        <div class={`rounded-2xl border p-6 relative flex flex-col h-full ${
          plan.variant === 'highlight'
            ? 'border-brand-500 shadow-xl shadow-brand-100/50 dark:shadow-brand-900/20 bg-brand-600'
            : plan.variant === 'dark'
            ? 'border-slate-700 bg-slate-900 dark:bg-slate-950'
            : plan.variant === 'outline'
            ? 'border-dashed border-slate-300 dark:border-slate-800 bg-slate-50 dark:bg-slate-900'
            : 'border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900'
        }`}>
          {plan.popular && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="bg-egg-500 text-white text-xs font-bold px-3 py-1 rounded-full whitespace-nowrap shadow-sm">
                Más popular
              </span>
            </div>
          )}

          <div class="mb-5">
            <h3 class={`font-bold text-lg mb-1 ${plan.variant === 'highlight' || plan.variant === 'dark' ? 'text-white' : 'text-slate-900 dark:text-white'}`}>
              {plan.name}
            </h3>
            <p class={`text-xs mb-4 leading-relaxed ${plan.variant === 'highlight' ? 'text-white/70' : plan.variant === 'dark' ? 'text-slate-400' : 'text-slate-500 dark:text-slate-400'}`}>
              {plan.desc}
            </p>
            <div class="flex items-end gap-1">
              <span class={`text-3xl font-extrabold ${plan.variant === 'highlight' || plan.variant === 'dark' ? 'text-white' : 'text-slate-900 dark:text-white'}`}>
                {plan.price}
              </span>
              <span class={`text-xs mb-1.5 ${plan.variant === 'highlight' ? 'text-white/70' : plan.variant === 'dark' ? 'text-slate-400' : 'text-slate-500 dark:text-slate-400'}`}>
                {plan.period}
              </span>
            </div>
          </div>

          <ul class="space-y-2.5 mb-6 flex-1">
            {plan.features.map((feat) => (
              <li class="flex items-start gap-2">
                <svg class={`w-4 h-4 mt-0.5 flex-shrink-0 ${plan.variant === 'highlight' ? 'text-white' : plan.variant === 'dark' ? 'text-brand-400' : 'text-brand-600 dark:text-brand-400'}`} xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                <span class={`text-sm ${plan.variant === 'highlight' ? 'text-white/90' : plan.variant === 'dark' ? 'text-slate-300' : 'text-slate-600 dark:text-slate-300'}`}>{feat}</span>
              </li>
            ))}
          </ul>

          <a
            href={plan.ctaLink}
            class={`block w-full text-center font-semibold py-3 rounded-xl transition-colors text-sm cursor-pointer ${
              plan.variant === 'highlight'
                ? 'bg-white text-brand-600 hover:bg-brand-50'
                : plan.variant === 'dark'
                ? 'bg-brand-600 text-white hover:bg-brand-500'
                : plan.variant === 'outline'
                ? 'bg-brand-600 text-white hover:bg-brand-700'
                : 'bg-brand-600 text-white hover:bg-brand-700'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <p class="text-center text-sm text-slate-500 dark:text-slate-500 mt-8">
      Precios en soles peruanos (PEN) · Aceptamos Yape, Plin, Mercado Pago y tarjeta de crédito/débito
    </p>
  </div>
</section>
