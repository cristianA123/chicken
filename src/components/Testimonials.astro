---
const testimonials = [
  {
    name: 'Carlos Quispe',
    role: 'Propietario, Granja San Martín',
    location: 'Ica, Perú',
    text: 'Antes llevaba todo en cuadernos y siempre me perdía datos. Con MiAgroGestion sé exactamente cuánto estoy produciendo cada día y tengo alertas cuando el stock de alimento está bajo.',
    stars: 5,
    avatar: 'CQ',
    color: 'brand',
  },
  {
    name: 'Milagros Ramos',
    role: 'Administradora, Avícola El Valle',
    location: 'Arequipa, Perú',
    text: 'Lo que más me gusta es ver la rentabilidad por galpón. Descubrí que uno consumía 20% más alimento de lo normal. Nunca lo hubiera visto en mi Excel anterior.',
    stars: 5,
    avatar: 'MR',
    color: 'amber',
  },
  {
    name: 'Javier Morales',
    role: 'Gerente de producción, AviCorp S.A.',
    location: 'Lima, Perú',
    text: 'Tenemos 3 granjas con 15,000 gallinas. MiAgroGestion nos permite ver todo desde una sola pantalla. El registro diario por turno nos ahorró mucho tiempo.',
    stars: 5,
    avatar: 'JM',
    color: 'slate',
  },
];
---
<section class="py-20 bg-slate-50 dark:bg-slate-900 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <p class="text-brand-600 dark:text-brand-400 font-semibold text-sm uppercase tracking-wider mb-3">Testimonios</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-4 text-balance">
        Granjeros que ya usan MiAgroGestion
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-100 dark:border-slate-800 shadow-sm flex flex-col transition-colors">
          <div class="flex gap-1 mb-4">
            {Array.from({ length: t.stars }).map(() => (
              <svg class="w-4 h-4 text-egg-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          <blockquote class="text-slate-700 dark:text-slate-300 text-sm leading-relaxed flex-1 mb-5">
            "{t.text}"
          </blockquote>
          <div class="flex items-center gap-3 pt-4 border-t border-slate-100 dark:border-slate-800">
            <div class={`w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0 ${
              t.color === 'brand' ? 'bg-brand-50 dark:bg-brand-600/20 text-brand-700 dark:text-brand-400'
              : t.color === 'amber' ? 'bg-egg-500/10 text-egg-600'
              : 'bg-slate-200 dark:bg-slate-800 text-slate-700 dark:text-slate-300'
            }`}>
              {t.avatar}
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-900 dark:text-white">{t.name}</p>
              <p class="text-xs text-slate-500 dark:text-slate-400">{t.role} · {t.location}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-wrap justify-center items-center gap-8 opacity-60">
      {[
        { label: 'Datos 100% seguros' },
        { label: 'Sin cobros ocultos' },
        { label: 'Soporte por WhatsApp' },
        { label: 'Funciona offline' },
      ].map(b => (
        <div class="flex items-center gap-2 text-slate-600 dark:text-slate-400 text-sm font-medium">
          <svg class="w-4 h-4 text-brand-600 dark:text-brand-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          {b.label}
        </div>
      ))}
    </div>
  </div>
</section>
