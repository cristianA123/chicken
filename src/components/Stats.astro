---
const stats = [
  { value: '500+', label: 'Granjas activas', sub: 'en Perú y LATAM' },
  { value: '11', label: 'Módulos integrados', sub: 'en una sola app' },
  { value: '<30s', label: 'Registro diario', sub: 'desde tu celular' },
  { value: '14 días', label: 'Prueba gratis', sub: 'sin tarjeta de crédito' },
];
---
<section class="py-12 bg-slate-900 dark:bg-slate-950 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {stats.map((s) => (
        <div class="text-center">
          <p class="text-3xl sm:text-4xl font-extrabold text-white mb-1">{s.value}</p>
          <p class="text-sm font-semibold text-brand-400 mb-0.5">{s.label}</p>
          <p class="text-xs text-slate-500">{s.sub}</p>
        </div>
      ))}
    </div>
  </div>
</section>
