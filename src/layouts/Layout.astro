---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical = 'https://avicontrol.app',
  ogImage = 'https://avicontrol.app/og-image.png',
} = Astro.props;
---

<!doctype html>
<html lang="es-419">
  <head>
    <!-- Anti-flash: aplica el tema ANTES de que el navegador pinte (debe ser el primer script) -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('mag_theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && prefersDark)) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        } catch (e) {}
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- SEO primario -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="es-419" />
    <meta name="geo.region" content="PE" />
    <meta name="geo.placename" content="Peru" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content="MiAgroGestion" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Structured Data: SoftwareApplication -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "MiAgroGestion",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web, Android, iOS",
        "offers": [
          {
            "@type": "Offer",
            "name": "Plan Prueba",
            "price": "0",
            "priceCurrency": "PEN",
            "description": "14 días gratis sin tarjeta"
          },
          {
            "@type": "Offer",
            "name": "Plan Productor",
            "price": "49",
            "priceCurrency": "PEN",
            "billingIncrement": "P1M"
          },
          {
            "@type": "Offer",
            "name": "Plan Profesional",
            "price": "99",
            "priceCurrency": "PEN",
            "billingIncrement": "P1M"
          },
          {
            "@type": "Offer",
            "name": "Plan Empresa",
            "price": "199",
            "priceCurrency": "PEN",
            "billingIncrement": "P1M"
          }
        ],
        "description": "Software SaaS para granjas de gallinas ponedoras en Latinoamérica. Control de postura, registro diario, ventas de huevos, gastos e inventario desde el celular.",
        "url": "https://miagrogesion.com",
        "inLanguage": "es-419",
        "audience": {
          "@type": "Audience",
          "audienceType": "Productores avícolas de Latinoamérica"
        },
        "featureList": [
          "Control de porcentaje de postura",
          "Registro diario de producción por turno",
          "Gestión de lotes, galpones y granjas",
          "Ventas de huevos por talla y unidad",
          "Control de gastos e inventario",
          "Dashboard con KPIs en tiempo real",
          "Alertas automáticas de stock y producción"
        ]
      }
    </script>

    <!-- Structured Data: Organization -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "MiAgroGestion",
        "url": "https://miagrogesion.com",
        "logo": "https://miagrogesion.com/logo.svg",
        "sameAs": [],
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "customer support",
          "telephone": "+51955497368",
          "availableLanguage": "Spanish"
        }
      }
    </script>

    <!-- Theme color para móvil (se actualiza con JS) -->
    <meta name="theme-color" content="#ffffff" id="theme-color-meta" />

    <!-- Preconnect para fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="bg-white dark:bg-slate-950 transition-colors duration-300">
    <slot />
  </body>
</html>
